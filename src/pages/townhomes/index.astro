---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABand from '../../components/CTABand.astro';
import FAQSection from '../../components/FAQSection.astro';
import GatedDownload from '../../components/GatedDownload.astro';
import { pages } from '../../data/seo';
import { townhomeFaqs } from '../../data/faqs';
import { PROJECT, formatPrice } from '../../data/project';
import { faqSchema, productOffersSchema } from '../../utils/schema';
---

<BaseLayout
  title={pages.townhomes.title}
  description={pages.townhomes.description}
  path={pages.townhomes.path}
  ogImage={pages.townhomes.ogImage}
  schemas={[faqSchema(townhomeFaqs), ...productOffersSchema(['village-townhomes', 'rear-lane-townhomes'])]}
>
  <PageHero
    h1={pages.townhomes.h1}
    tag="Freehold & Rear Lane · Milton"
    num="TH"
    crumbs={[{ name: 'Townhomes', path: '/townhomes/' }]}
    description="Hawthorne East Village offers freehold Village townhomes and common-element Rear Lane townhomes in Milton — Halton Region freehold and low-rise living by Mattamy Homes."
  />

  <section class="section-pad">
    <div class="container-narrow grid gap-10 lg:grid-cols-2">
      <article class="rounded-lg border bg-white p-8">
        <h2 class="text-2xl text-forest-dark">Village Townhomes</h2>
        <p class="mt-3 text-forest-mid">{PROJECT.homeTypes[0].description}</p>
        <ul class="mt-4 space-y-2 text-sm font-medium">
          <li>From {formatPrice(PROJECT.homeTypes[0].priceFrom)}*</li>
          <li>{PROJECT.homeTypes[0].beds} bed · {PROJECT.homeTypes[0].baths} bath</li>
          <li>
            {PROJECT.homeTypes[0].sizeMin.toLocaleString()} – {PROJECT.homeTypes[0].sizeMax.toLocaleString()} sq ft
          </li>
          <li>Freehold ownership</li>
        </ul>
      </article>
      <article class="rounded-lg border bg-white p-8">
        <h2 class="text-2xl text-forest-dark">Rear Lane Townhomes</h2>
        <p class="mt-3 text-forest-mid">{PROJECT.homeTypes[1].description}</p>
        <ul class="mt-4 space-y-2 text-sm font-medium">
          <li>From {formatPrice(PROJECT.homeTypes[1].priceFrom)}*</li>
          <li>{PROJECT.homeTypes[1].beds} bed · {PROJECT.homeTypes[1].baths} bath</li>
          <li>
            {PROJECT.homeTypes[1].sizeMin.toLocaleString()} – {PROJECT.homeTypes[1].sizeMax.toLocaleString()} sq ft
          </li>
          <li>Common-element with rear garage access</li>
        </ul>
      </article>
    </div>
    <div class="container-narrow mt-8 grid gap-8 md:grid-cols-2">
      <img
        src="/images/1780773913253_townhomes.jpg"
        alt="Hawthorne East Village Milton village townhomes by Mattamy Homes"
        width={800}
        height={600}
        loading="lazy"
        class="w-full rounded-lg object-cover shadow-sm"
      />
      <img
        src="/images/1780773913252_townhomes_3_storey.jpeg"
        alt="Hawthorne East Village Milton rear lane townhomes by Mattamy Homes"
        width={800}
        height={600}
        loading="lazy"
        class="w-full rounded-lg object-cover shadow-sm"
      />
    </div>
    <p class="container-narrow mt-4 text-xs text-forest-mid">*Starting from, subject to change. E&OE.</p>
    <div class="container-narrow mt-8 flex flex-wrap gap-4">
      <GatedDownload buttonLabel="Get Townhome Pricing" modalTitle="Hawthorne East Village Townhome VIP Package" formType="townhomes" />
      <a href="/floor-plans/" class="btn-outline">View Floor Plans</a>
    </div>
  </section>

  <FAQSection faqs={townhomeFaqs} heading="Hawthorne East Village Townhome FAQs" id="townhome-faq" />

  <CTABand />
</BaseLayout>
