---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pages } from '../../data/seo';
---

<BaseLayout
  title={pages.thankYou.title}
  description={pages.thankYou.description}
  path={pages.thankYou.path}
  ogImage={pages.thankYou.ogImage}
  noindex={true}
>
  <section class="section-pad bg-stone">
    <div class="container-wide mx-auto max-w-3xl">
      <span class="section-num" aria-hidden="true">✓</span>
      <h1 class="mt-4 display-h1 text-midnight">{pages.thankYou.h1}</h1>
      <p class="mt-6 text-lg text-slate">
        Your VIP registration for Hawthorne East Village Milton has been received. Our team will contact you
        within the next few minutes with your package.
      </p>

      <div class="mt-12 border border-stone-dark bg-snow p-8 sm:p-10">
        <span class="label-tag">Your VIP Package</span>
        <h2 class="mt-5 font-display text-3xl font-semibold text-midnight">What's Inside</h2>
        <p class="mt-3 text-sm text-slate">
          Our team will send the current price list and floor plans directly.
        </p>
        <ul class="mt-8 grid gap-3 sm:grid-cols-2">
          <li>
            <a href="/prices/" class="flex items-center justify-between border border-stone-dark px-5 py-4 text-sm font-bold uppercase tracking-[0.15em] text-midnight transition-colors hover:border-terracotta hover:text-terracotta">
              Price overview <span aria-hidden="true">→</span>
            </a>
          </li>
          <li>
            <a href="/floor-plans/" class="flex items-center justify-between border border-stone-dark px-5 py-4 text-sm font-bold uppercase tracking-[0.15em] text-midnight transition-colors hover:border-terracotta hover:text-terracotta">
              Floor plans <span aria-hidden="true">→</span>
            </a>
          </li>
        </ul>
      </div>

      <div class="mt-12">
        <span class="label-tag">What Happens Next</span>
        <ol class="mt-6 space-y-6 text-slate">
          <li class="flex gap-5 border-b border-stone-dark pb-6">
            <span class="font-display text-3xl text-terracotta">01</span>
            Our team reviews your registration and preferred home type.
          </li>
          <li class="flex gap-5 border-b border-stone-dark pb-6">
            <span class="font-display text-3xl text-terracotta">02</span>
            You receive a call or text at the number you provided.
          </li>
          <li class="flex gap-5">
            <span class="font-display text-3xl text-terracotta">03</span>
            Current pricing, floor plans, and incentive details are shared for your phase.
          </li>
        </ol>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function fireConversion() {
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', {
        event_category: 'Lead',
        event_label: 'hawthorneeastvillagemilton.com',
      });
    }
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'Lead');
    }
    console.info('[Conversion] generate_lead fired');
  }

  fireConversion();
</script>

<script is:inline>
  window.dataLayer = window.dataLayer || [];
</script>
