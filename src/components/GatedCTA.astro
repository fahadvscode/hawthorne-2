---
interface Props {
  label: string;
  modalTitle: string;
  formType?: string;
}

const { label, modalTitle, formType = 'gated-download' } = Astro.props;
const modalId = `modal-${formType}`;
---

<button
  type="button"
  class="btn-gold w-full sm:w-auto"
  data-open-modal={modalId}
  aria-haspopup="dialog"
>
  {label}
</button>

<dialog
  id={modalId}
  class="fixed inset-0 z-[60] m-auto max-h-[90vh] w-[calc(100%-2rem)] max-w-md overflow-y-auto border-0 bg-snow p-0 shadow-2xl backdrop:bg-midnight/75 open:flex open:flex-col"
  aria-labelledby={`${modalId}-title`}
>
  <div class="border-b border-stone-dark bg-midnight px-6 py-5 text-white">
    <div class="flex items-start justify-between gap-4">
      <div>
        <span class="label-tag-light">VIP Access</span>
        <h2 id={`${modalId}-title`} class="mt-3 font-display text-2xl font-semibold">{modalTitle}</h2>
      </div>
      <button type="button" class="min-h-11 min-w-11 text-white hover:text-terracotta" data-close-modal={modalId} aria-label="Close dialog">✕</button>
    </div>
  </div>
  <div class="p-6 sm:p-8">
    <p class="mb-5 text-sm text-slate">
      Enter your details to receive your VIP package. Our team will follow up shortly.
    </p>
    <slot />
  </div>
</dialog>

<script>
  function initModals() {
    document.querySelectorAll('[data-open-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-open-modal');
        const dialog = document.getElementById(id!) as HTMLDialogElement;
        dialog?.showModal();
      });
    });
    document.querySelectorAll('[data-close-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-close-modal');
        const dialog = document.getElementById(id!) as HTMLDialogElement;
        dialog?.close();
      });
    });
    document.querySelectorAll('dialog').forEach((dialog) => {
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
    });
  }
  initModals();
  document.addEventListener('astro:page-load', initModals);
</script>
