---
import LeadForm from './LeadForm.astro';
import { PROJECT, formatPrice } from '../data/project';

interface Props {
  h1: string;
  subtitle: string;
  showForm?: boolean;
}

const { h1, subtitle, showForm = true } = Astro.props;

const headlineParts = h1.includes('—')
  ? { main: h1.split('—')[0].trim(), accent: h1.split('—').slice(1).join('—').trim() }
  : { main: h1, accent: null };
---

<section class="relative overflow-hidden bg-white">
  <!-- Brand accent strip -->
  <div class="h-1.5 w-full bg-brand" aria-hidden="true"></div>

  <div class="container-wide">
    <div class="grid min-h-[calc(100svh-6px)] lg:grid-cols-12 lg:gap-0">
      <!-- Left: copy on white -->
      <div class="flex flex-col justify-center px-5 py-12 sm:px-8 lg:col-span-5 lg:py-20 lg:pr-12">
        <span class="label-tag mb-6 w-fit">Pre-Construction · Milton, ON</span>

        <h1 class="hero-headline">
          {headlineParts.main}
          {headlineParts.accent && (
            <>
              <span class="block mt-2 text-brand">{headlineParts.accent}</span>
            </>
          )}
        </h1>

        <p class="mt-6 max-w-lg text-base leading-relaxed text-slate sm:text-lg">
          {subtitle}
        </p>

        <dl class="mt-10 grid grid-cols-3 gap-4">
          <div class="rounded-xl border border-brand/20 bg-brand-soft px-3 py-4 text-center sm:px-4">
            <dt class="text-[9px] font-bold uppercase tracking-[0.2em] text-brand sm:text-[10px]">From</dt>
            <dd class="mt-1 font-display text-lg font-semibold text-charcoal sm:text-xl">
              {formatPrice(PROJECT.priceRange.low)}
            </dd>
          </div>
          <div class="rounded-xl border border-brand/20 bg-brand-soft px-3 py-4 text-center sm:px-4">
            <dt class="text-[9px] font-bold uppercase tracking-[0.2em] text-brand sm:text-[10px]">Sizes</dt>
            <dd class="mt-1 font-display text-lg font-semibold text-charcoal sm:text-xl">
              {PROJECT.sizes.min.toLocaleString()}+
            </dd>
          </div>
          <div class="rounded-xl border border-brand/20 bg-brand-soft px-3 py-4 text-center sm:px-4">
            <dt class="text-[9px] font-bold uppercase tracking-[0.2em] text-brand sm:text-[10px]">Builder</dt>
            <dd class="mt-1 font-display text-lg font-semibold text-charcoal sm:text-xl">Mattamy</dd>
          </div>
        </dl>

        <ul class="mt-8 space-y-3 text-sm text-slate">
          <li class="flex items-center gap-3">
            <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand text-white">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </span>
            Freehold townhomes & detached homes
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand text-white">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </span>
            Priority pricing & floor plans
          </li>
          <li class="flex items-center gap-3">
            <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand text-white">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </span>
            Exclusive VIP incentives
          </li>
        </ul>

        {
          !showForm && (
            <a href="/register/" class="btn-gold mt-10 w-fit">
              Get VIP Pricing & Floor Plans
            </a>
          )
        }
      </div>

      <!-- Right: image + floating form -->
      <div class="relative lg:col-span-7">
        <div class="relative h-[45vh] min-h-[320px] lg:absolute lg:inset-0 lg:h-auto">
          <img
            src="/images/1780773913252_hero_community_picture.webp"
            alt="Hawthorne East Village Milton new home community by Mattamy Homes pre-construction"
            width={1920}
            height={1080}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="h-full w-full object-cover lg:rounded-bl-[3rem]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-darker/50 via-transparent to-transparent lg:bg-gradient-to-l lg:from-transparent lg:via-transparent lg:to-white/20" aria-hidden="true"></div>
          <div class="absolute bottom-0 left-0 right-0 h-1 bg-brand lg:hidden" aria-hidden="true"></div>
        </div>

        {
          showForm && (
            <div class="relative z-10 mx-5 -mt-10 mb-10 sm:mx-8 lg:absolute lg:bottom-10 lg:left-8 lg:right-8 lg:mx-0 lg:mb-0 lg:max-w-md lg:ml-auto">
              <div class="card-elevated overflow-hidden">
                <div class="bg-brand px-6 py-4 text-white">
                  <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-white/80">VIP Registration</p>
                  <h2 class="mt-1 font-display text-2xl font-semibold">Floor Plans & Pricing</h2>
                  <p class="mt-1 text-sm text-white/80">Delivered to your inbox instantly.</p>
                </div>
                <div class="bg-white px-6 py-6 sm:px-7 sm:py-7">
                  <LeadForm id="hero-form" variant="inline" formType="hero" />
                </div>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<link rel="preload" as="image" href="/images/1780773913252_hero_community_picture.webp" type="image/webp" fetchpriority="high" />
