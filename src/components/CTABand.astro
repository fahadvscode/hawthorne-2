---
import { PROJECT, formatPrice } from '../data/project';
---

<section class="relative overflow-hidden bg-brand">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="h-full w-full bg-[radial-gradient(circle_at_30%_50%,white_0%,transparent_60%)]"></div>
  </div>

  <div class="container-wide section-pad relative z-10 grid gap-10 lg:grid-cols-2 lg:items-center">
    <div>
      <span class="label-tag-light">Limited VIP Phase</span>
      <h2 class="mt-6 font-display text-4xl font-semibold text-white sm:text-5xl lg:text-6xl">
        Register for Hawthorne East Village VIP Access
      </h2>
      <p class="mt-5 max-w-lg text-base leading-relaxed text-white/90">
        Priority pricing, floor plans, deposit schedules, and current incentives — delivered before the public launch in Milton.
      </p>
    </div>

    <div class="rounded-2xl border border-white/25 bg-white p-8 sm:p-10">
      <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-brand">From {formatPrice(PROJECT.priceRange.low)}</p>
      <p class="mt-2 font-display text-3xl font-semibold text-charcoal">
        Two minutes. Zero obligation.
      </p>
      <p class="mt-3 text-sm text-slate">
        Submit your details and we'll send floor plans, the VIP price sheet, and deposit structure.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/register/" class="btn-gold flex-1 text-center">VIP Registration</a>
        <a href="/prices/" class="inline-flex min-h-12 flex-1 items-center justify-center rounded-lg border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-[0.2em] text-brand transition-colors hover:bg-brand hover:text-white">
          See Prices
        </a>
      </div>
    </div>
  </div>
</section>
